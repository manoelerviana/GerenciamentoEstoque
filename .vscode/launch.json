{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Streamlit app",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "CadastroProdutos/app.py",
        "--server.port=8501"
      ],
      "console": "integratedTerminal",
      "subProcess": true,
      "justMyCode": false
    },
    {
      "name": "Attach to Streamlit",
      "type": "python",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "${workspaceFolder}"
        }
      ]
    }
  ]
}
 